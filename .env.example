# AdvantShop (shop.synonym-jewelry.ru)
ADVANTSHOP_BASE_URL=https://shop.synonym-jewelry.ru
ADVANTSHOP_SERVER_API_KEY=your_server_api_key
# Или полный URL со страницы «Настройки → API → 1C → Импорт товаров»:
# ADVANTSHOP_1C_IMPORT_URL=https://shop.synonym-jewelry.ru/api/1c/importproducts?apikey=...

# FTP Терры (файл от 1С)
FTP_HOST=ftp.example.ru
FTP_USER=sinonim
FTP_PASSWORD=secret
FTP_REMOTE_PATH=/sinonim/stocks.csv
FTP_PORT=21
FTP_SECURE=false

# Колонки CSV 1С → AdvantShop (при необходимости)
# SYNC_SRC_ARTNO=ArtNo
# SYNC_SRC_OFFER=OfferArtNo
# SYNC_SRC_AMOUNT=Amount
# SYNC_SRC_PRICE=Price
# SYNC_DST_ARTNO=ArtNo
# SYNC_DST_OFFER=MultiOffer
# SYNC_DST_AMOUNT=Amount
# SYNC_DST_PRICE=Price
# SYNC_POST_MODE=multipart
# SYNC_SKIP_IF_UNCHANGED=true
